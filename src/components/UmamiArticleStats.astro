---
interface Props {
    url: string;
}
const { url } = Astro.props;

// 【注意事项】: 使用提供的 Umami 分享凭证
const WEBSITE_ID = "8cb717a8-418f-4347-bea6-0eda398b8d65";
const TOKEN = "";
---
<umami-article-stats data-url={url} data-website={WEBSITE_ID} data-token={TOKEN} class="contents">
    <slot />
</umami-article-stats>

<script>
    class UmamiArticleStats extends HTMLElement {
        connectedCallback() {
            // 获取相关的配置数据
            const url = this.dataset.url;
            const website = this.dataset.website;
            const token = this.dataset.token;
            
            // 确保组件不会重复初始化
            if (this.dataset.loaded) return;
            this.dataset.loaded = 'true';
            
            // 获取当前组件内部需要展示数据的DOM节点，避免影响其他文章卡片
            const viewsEls = this.querySelectorAll('.umami-views');
            const visitsEls = this.querySelectorAll('.umami-visits');
            
            if (!url || !website || !token) return;
            
            const endAt = Date.now();
            const startAt = 0;
            const apiUrl = `https://cloud.umami.is/analytics/us/api/websites/${website}/metrics/expanded?startAt=${startAt}&endAt=${endAt}&search=${url}&type=path`;

            // 调用Umami接口
            fetch(apiUrl, {
                method: 'GET',
                headers: {
                    'Content-Type': 'application/json',
                    Authorization: `Bearer ${token}`
                }
            })
            .then(res => {
                if (!res.ok) throw new Error('网络请求失败');
                return res.json();
            })
            .then(data => {
                let pageviews = 0;
                let visits = 0;

                // 兼容数组或对象数据响应 (metrics/expanded 通常返回数组，stats 通常返回对象)
                if (Array.isArray(data)) {
                    if (data.length > 0) {
                        pageviews = data[0].pageviews || data[0].y || 0;
                        visits = data[0].visits || 0;
                    }
                } else if (data) {
                    pageviews = data.pageviews?.value || data.pageviews || 0;
                    visits = data.visits?.value || data.visits || 0;
                }
                
                // 格式化数字以提高可读性
                const viewsStr = Number(pageviews).toLocaleString();
                const visitsStr = Number(visits).toLocaleString();
                
                // 更新每篇文章的浏览量和访问次数DOM展示
                viewsEls.forEach(el => el.textContent = viewsStr);
                visitsEls.forEach(el => el.textContent = visitsStr);
            })
            .catch(err => {
                console.error('获取 Umami 统计失败:', err);
                viewsEls.forEach(el => el.textContent = '-');
                visitsEls.forEach(el => el.textContent = '-');
            });
        }
    }
    
    // 注册自定义组件
    if (!customElements.get('umami-article-stats')) {
        customElements.define('umami-article-stats', UmamiArticleStats);
    }
</script>
