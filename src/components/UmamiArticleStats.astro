---
interface Props {
	url: string;
}
const { url } = Astro.props;
---

<umami-article-stats data-url={url} class="contents">
    <slot />
</umami-article-stats>

<script>
    import { animateValue } from '@utils/animation-utils';

    class UmamiArticleStats extends HTMLElement {
        connectedCallback() {
            // 获取相关的配置数据
            const url = this.dataset.url;
            
            // 确保组件不会重复初始化
            if (this.dataset.loaded) return;
            this.dataset.loaded = 'true';
            
            // 获取当前组件内部需要展示数据的DOM节点，避免影响其他文章卡片
            const viewsEls = this.querySelectorAll('.umami-views');
            const visitsEls = this.querySelectorAll('.umami-visits');
            
            if (!url) return;

            const cacheKey = 'umamiSiteStatsPromise';

            if (!(window as any)[cacheKey]) {
                // 如果页面首次初始化请求，则发起一次获取请求
                const globalWorkerUrl = `https://umami.temperaturetw.top/?url=/posts/`;

                (window as any)[cacheKey] = fetch(globalWorkerUrl, {
                    method: 'GET',
                    headers: { 'Content-Type': 'application/json' }
                }).then(res => {
                    if (!res.ok) throw new Error('网络请求失败');
                    return res.json();
                });
            }

            // 所有文章卡片等待这唯一的 Promise 请求解决，从而提取他自己的 url 数据
            (window as any)[cacheKey]
            .then((dataList: any) => {
                let pageviews = 0;
                let visits = 0;

                // 在返回的全体对象字典 / 数组中寻找符合当前卡片 url 的那项
                if (Array.isArray(dataList)) {
                    const matchedUrl = dataList.find((item: any) => item.name === url);
                    if (matchedUrl) {
                        pageviews = matchedUrl.pageviews || 0;
                        visits = matchedUrl.visits || 0;
                    } else {
                        pageviews = 0;
                        visits = 0;
                    }
                }
                
                // 仅当找到数据时触发动画
                if (pageviews > 0 || visits > 0) {
                    viewsEls.forEach((el) => animateValue(el, pageviews));
                    visitsEls.forEach((el) => animateValue(el, visits));
                } else {
                    viewsEls.forEach(el => el.textContent = '0');
                    visitsEls.forEach(el => el.textContent = '0');
                }
            })
            .catch((err: any) => {
                console.error('获取 Umami 统计失败:', err);
                viewsEls.forEach(el => el.textContent = '-');
                visitsEls.forEach(el => el.textContent = '-');
            });
        }
    }
    
    // 注册自定义组件
    if (!customElements.get('umami-article-stats')) {
        customElements.define('umami-article-stats', UmamiArticleStats);
    }
</script>
