---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import { profileConfig } from "../../config";
import { url } from "../../utils/url-utils";
import ImageWrapper from "../misc/ImageWrapper.astro";

const config = profileConfig;

// 获取文章、标签、字数统计数据
const allPosts = await getCollection("posts"); // .filter(post => !post.data.draft); (除去草稿)
let wordCount = 0;
const tags = new Set<string>();

for (const post of allPosts) {
	if (post.data.tags) {
		post.data.tags.forEach((t) => tags.add(t));
	}
	const { remarkPluginFrontmatter } = await post.render();
	wordCount += remarkPluginFrontmatter.words || 0;
}
const tagCount = tags.size;
const articleCount = allPosts.length;
---
<div class="card-base p-3">
    <a aria-label="Go to About Page" href={url('/about/')}
       class="group block relative mx-auto mt-1 lg:mx-0 lg:mt-0 mb-3
       max-w-[12rem] lg:max-w-none overflow-hidden rounded-xl active:scale-95">
        <div class="absolute transition pointer-events-none group-hover:bg-black/30 group-active:bg-black/50
        w-full h-full z-50 flex items-center justify-center">
            <Icon name="fa6-regular:address-card"
                  class="transition opacity-0 scale-90 group-hover:scale-100 group-hover:opacity-100 text-white text-5xl">
            </Icon>
        </div>
        <ImageWrapper src={config.avatar || ""} alt="Profile Image of the Author" class="mx-auto lg:w-full h-full lg:mt-0 "></ImageWrapper>
    </a>
    <div class="px-2">
        <div class="font-bold text-xl text-center mb-1 dark:text-neutral-50 transition">{config.name}</div>
        <div class="h-1 w-5 bg-[var(--primary)] mx-auto rounded-full mb-2 transition"></div>
        <div class="text-center text-neutral-400 mb-2.5 transition">{config.bio}</div>
        <div class="flex flex-wrap gap-2 justify-center mb-1">
            {config.links.length > 1 && config.links.map(item =>
                    <a rel="me" aria-label={item.name} href={item.url} target="_blank" class="btn-regular rounded-lg h-10 w-10 active:scale-90">
                        <Icon name={item.icon} class="text-[1.5rem]"></Icon>
                    </a>
            )}
            {config.links.length == 1 && <a rel="me" aria-label={config.links[0].name} href={config.links[0].url} target="_blank"
                                            class="btn-regular rounded-lg h-10 gap-2 px-3 font-bold active:scale-95">
                <Icon name={config.links[0].icon} class="text-[1.5rem]"></Icon>
                {config.links[0].name}
            </a>}
        </div>
        
        <div class="grid grid-cols-2 gap-2 mt-4 mb-2">
            <div class="flex items-center justify-between px-3 py-2 bg-[var(--card-bg)] dark:bg-white/5 rounded-xl border border-black/5 dark:border-white/5 transition">
                <div class="flex items-center gap-1.5 text-neutral-500 dark:text-neutral-400">
                    <Icon name="material-symbols:book-2-outline-rounded" class="text-xl"></Icon>
                    <span class="text-sm font-medium">文章</span>
                </div>
                <span id="profile-article-count" data-val={articleCount} class="font-bold text-neutral-700 dark:text-neutral-200">0</span>
            </div>
            <div class="flex items-center justify-between px-3 py-2 bg-[var(--card-bg)] dark:bg-white/5 rounded-xl border border-black/5 dark:border-white/5 transition">
                <div class="flex items-center gap-1.5 text-neutral-500 dark:text-neutral-400">
                    <Icon name="material-symbols:tag-rounded" class="text-xl"></Icon>
                    <span class="text-sm font-medium">标签</span>
                </div>
                <span id="profile-tag-count" data-val={tagCount} class="font-bold text-neutral-700 dark:text-neutral-200">0</span>
            </div>
            <div class="col-span-2 flex items-center justify-between px-3 py-2 bg-[var(--card-bg)] dark:bg-white/5 rounded-xl border border-black/5 dark:border-white/5 transition">
                <div class="flex items-center gap-1.5 text-neutral-500 dark:text-neutral-400">
                    <Icon name="material-symbols:text-snippet-outline-rounded" class="text-xl"></Icon>
                    <span class="text-sm font-medium">字数</span>
                </div>
                <span id="profile-word-count" data-val={wordCount} class="font-bold text-neutral-700 dark:text-neutral-200">0</span>
            </div>
            <div class="col-span-2 flex items-center justify-between px-3 py-2 bg-[var(--card-bg)] dark:bg-white/5 rounded-xl border border-black/5 dark:border-white/5 transition">
                <div class="flex items-center gap-1.5 text-neutral-500 dark:text-neutral-400">
                    <Icon name="material-symbols:schedule-outline-rounded" class="text-xl"></Icon>
                    <span class="text-sm font-medium">运行</span>
                </div>
                <span id="profile-uptime" class="font-bold text-neutral-700 dark:text-neutral-200">...</span>
            </div>
        </div>
    </div>
</div>

<script>
    import { animateValue } from '@utils/animation-utils';

    const setupProfileStatsAnimation = () => {
        const articleCountEl = document.getElementById('profile-article-count');
        const tagCountEl = document.getElementById('profile-tag-count');
        const wordCountEl = document.getElementById('profile-word-count');

        if (articleCountEl) {
            const val = Number.parseInt(articleCountEl.getAttribute('data-val') || '0', 10);
            animateValue(articleCountEl, val);
        }

        if (tagCountEl) {
            const val = Number.parseInt(tagCountEl.getAttribute('data-val') || '0', 10);
            animateValue(tagCountEl, val);
        }

        if (wordCountEl) {
            const val = Number.parseInt(wordCountEl.getAttribute('data-val') || '0', 10);
            animateValue(wordCountEl, val, (currentVal) => {
                return currentVal > 10000 ? (currentVal / 10000).toFixed(1) + 'w' : currentVal.toString();
            });
        }

        const uptimeEl = document.getElementById('profile-uptime');
        if (uptimeEl) {
            // 建站日期（您可以自行在这里修改为真实的日期）
            const startDate = new Date('2026-03-01');
            const diffDays = Math.floor((new Date().getTime() - startDate.getTime()) / (1000 * 60 * 60 * 24));
            animateValue(uptimeEl, diffDays, (currentVal) => {
                return currentVal.toString() + ' 天';
            });
        }
    };

    // Run when the page is loaded or after view transitions
    document.addEventListener('astro:page-load', setupProfileStatsAnimation);
    // Also run immediately just in case
    setupProfileStatsAnimation();
</script>
