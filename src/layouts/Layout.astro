const bannerEnabled = !!document.getElementById('banner-wrapper')

function setClickOutsideToClose(panel: string, ignores: string[]) {
	document.addEventListener("click", event => {
		let panelDom = document.getElementById(panel);
		let tDom = event.target;
		if (!(tDom instanceof Node)) return;		// Ensure the event target is an HTML Node
		for (let ig of ignores) {
			let ie = document.getElementById(ig)
			if (ie == tDom || (ie?.contains(tDom))) {
				return;
			}
		}
		panelDom!.classList.add("float-panel-closed");
	});
}
setClickOutsideToClose("display-setting", ["display-setting", "display-settings-switch"])
setClickOutsideToClose("nav-menu-panel", ["nav-menu-panel", "nav-menu-switch"])
setClickOutsideToClose("search-panel", ["search-panel", "search-bar", "search-switch"])


function loadTheme() {
	const theme = getStoredTheme()
	setTheme(theme)
}

function loadHue() {
	setHue(getHue())
}

function loadBackgroundOpacity() {
	setBackgroundOpacity(getBackgroundOpacity())
}

function initCustomScrollbar() {
	const bodyElement = document.querySelector('body');
	if (!bodyElement) return;
	OverlayScrollbars(
		// docs say that a initialization to the body element would affect native functionality like window.scrollTo
		// but just leave it here for now
		{
			target: bodyElement,
			cancel: {
				nativeScrollbarsOverlaid: true,    // don't initialize the overlay scrollbar if there is a native one
			}
		}, {
		scrollbars: {
			theme: 'scrollbar-base scrollbar-auto py-1',
			autoHide: 'move',
			autoHideDelay: 500,
			autoHideSuspend: false,
		},
	});

	const katexElements = document.querySelectorAll('.katex-display') as NodeListOf<HTMLElement>;

	const katexObserverOptions = {
		root: null,
		rootMargin: '100px',
		threshold: 0.1
	};

	const processKatexElement = (element: HTMLElement) => {
		if (!element.parentNode) return;
		if (element.hasAttribute('data-scrollbar-initialized')) return;

		const container = document.createElement('div');
		container.className = 'katex-display-container';
		container.setAttribute('aria-label', 'scrollable container for formulas');

		element.parentNode.insertBefore(container, element);
		container.appendChild(element);

		OverlayScrollbars(container, {
			scrollbars: {
				theme: 'scrollbar-base scrollbar-auto',
				autoHide: 'leave',
				autoHideDelay: 500,
				autoHideSuspend: false
			}
		});

		element.setAttribute('data-scrollbar-initialized', 'true');
	};

	const katexObserver = new IntersectionObserver((entries, observer) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
			processKatexElement(entry.target as HTMLElement);
			observer.unobserve(entry.target);
			}
		});
	}, katexObserverOptions);

	katexElements.forEach(element => {
		katexObserver.observe(element);
	});
}

function showBanner() {
	if (!siteConfig.banner.enable) return;

	const banner = document.getElementById('banner');
	if (!banner) {
		console.error('Banner element not found');
		return;
	}

	banner.classList.remove('opacity-0', 'scale-105');
}

function init() {
	// disableAnimation()()		// TODO
	loadTheme();
	loadHue();
	loadBackgroundOpacity();
	initCustomScrollbar();
	showBanner();
}

/* Load settings when entering the site */
init();

const setup = () => {
	// TODO: temp solution to change the height of the banner
/*
	window.swup.hooks.on('animation:out:start', () => {
		const path = window.location.pathname
		const body = document.querySelector('body')
		if (path[path.length - 1] === '/' && !body.classList.contains('is-home')) {
			body.classList.add('is-home')
		} else if (path[path.length - 1] !== '/' && body.classList.contains('is-home')) {
			body.classList.remove('is-home')
		}
	})
*/
	window.swup.hooks.on('link:click', () => {
		// Remove the delay for the first time page load
		document.documentElement.style.setProperty('--content-delay', '0ms')

		// prevent elements from overlapping the navbar
		if (!bannerEnabled) {
			return
		}
		let threshold = window.innerHeight * (BANNER_HEIGHT / 100) - 72 - 16
		let navbar = document.getElementById('navbar-wrapper')
		if (!navbar || !document.body.classList.contains('lg:is-home')) {
			return
		}
		if (document.body.scrollTop >= threshold || document.documentElement.scrollTop >= threshold) {
			navbar.classList.add('navbar-hidden')
		}
	})
	window.swup.hooks.on('content:replace', initCustomScrollbar)
	window.swup.hooks.on('visit:start', (visit: {to: {url: string}}) => {
		// change banner height immediately when a link is clicked
		const bodyElement = document.querySelector('body')
		if (pathsEqual(visit.to.url, url('/'))) {
			bodyElement!.classList.add('lg:is-home');
		} else {
			bodyElement!.classList.remove('lg:is-home');
		}

		// increase the page height during page transition to prevent the scrolling animation from jumping
		const heightExtend = document.getElementById('page-height-extend')
		if (heightExtend) {
			heightExtend.classList.remove('hidden')
		}

		// Hide the TOC while scrolling back to top
		let toc = document.getElementById('toc-wrapper');
		if (toc) {
			toc.classList.add('toc-not-ready')
		}
	});
	window.swup.hooks.on('page:view', () => {
		// hide the temp high element when the transition is done
		const heightExtend = document.getElementById('page-height-extend')
		if (heightExtend) {
			heightExtend.classList.remove('hidden')
		}
        
        // 当 Swup 完成页面替换并准备显示新页面时，手动触发一条 Umami 数据
        if ((window as any).umami) {
            (window as any).umami.track();
        }
	});
	window.swup.hooks.on('visit:end', (_visit: {to: {url: string}}) => {
		setTimeout(() => {
			const heightExtend = document.getElementById('page-height-extend')
			if (heightExtend) {
				heightExtend.classList.add('hidden')
			}

            // Just make the transition looks better
            const toc = document.getElementById('toc-wrapper');
            if (toc) {
                toc.classList.remove('toc-not-ready')
            }
        }, 200)
	});
}
if (window?.swup?.hooks) {
	setup()
} else {
	document.addEventListener('swup:enable', setup)
}

// 首次打开网页时，手动触发一次追踪（兼容异步加载延迟）
let umamiCheckCount = 0;
const trackInitialPageview = () => {
    if ((window as any).umami) {
        (window as any).umami.track();
    } else if (umamiCheckCount < 30) {
        umamiCheckCount++;
        setTimeout(trackInitialPageview, 300);
    }
};
trackInitialPageview();

let backToTopBtn: HTMLElement | null = null;
let scrollToCommentsBtn: HTMLElement | null = null;
let commentsSection: HTMLElement | null = null;
let toc: HTMLElement | null = null;
let navbar: HTMLElement | null = null;

function refreshFloatingActionTargets() {
	backToTopBtn = document.getElementById('back-to-top-btn');
	scrollToCommentsBtn = document.getElementById('scroll-to-comments-btn');
	commentsSection = document.getElementById('comments-section');
	toc = document.getElementById('toc-wrapper');
	navbar = document.getElementById('navbar-wrapper');
}

refreshFloatingActionTargets();

function scrollFunction() {
	let bannerHeight = window.innerHeight * (BANNER_HEIGHT / 100)
	const scrollTop = window.scrollY || document.documentElement.scrollTop || document.body.scrollTop
	const scrollHeight = Math.max(document.body.scrollHeight, document.documentElement.scrollHeight)
	const clientHeight = document.documentElement.clientHeight

	if (backToTopBtn) {
		backToTopBtn.style.setProperty('--scroll-progress-angle', getScrollProgressAngle({
			scrollTop,
			scrollHeight,
			clientHeight,
		}))
		if (document.body.scrollTop > bannerHeight || document.documentElement.scrollTop > bannerHeight) {
			backToTopBtn.classList.remove('hide')
		} else {
			backToTopBtn.classList.add('hide')
		}
	}

	if (scrollToCommentsBtn) {
		if (commentsSection) {
			scrollToCommentsBtn.classList.remove('hide')
		} else {
			scrollToCommentsBtn.classList.add('hide')
		}
	}

	if (bannerEnabled && toc) {
		if (document.body.scrollTop > bannerHeight || document.documentElement.scrollTop > bannerHeight) {
			toc.classList.remove('toc-hide')
		} else {
			toc.classList.add('toc-hide')
		}
	}

	if (!bannerEnabled) return
	if (navbar) {
		const NAVBAR_HEIGHT = 72
		const MAIN_PANEL_EXCESS_HEIGHT = MAIN_PANEL_OVERLAPS_BANNER_HEIGHT * 16			// The height the main panel overlaps the banner

		let bannerHeight = BANNER_HEIGHT
		if (document.body.classList.contains('lg:is-home') && window.innerWidth >= 1024) {
			bannerHeight = BANNER_HEIGHT_HOME
		}
		let threshold = window.innerHeight * (bannerHeight / 100) - NAVBAR_HEIGHT - MAIN_PANEL_EXCESS_HEIGHT - 16
		if (document.body.scrollTop >= threshold || document.documentElement.scrollTop >= threshold) {
			navbar.classList.add('navbar-hidden')
		} else {
			navbar.classList.remove('navbar-hidden')
		}
	}
}
window.onscroll = scrollFunction
scrollFunction()

const syncFloatingActions = () => {
	refreshFloatingActionTargets()
	scrollFunction()
}

if (window.swup?.hooks) {
	window.swup.hooks.on('page:view', syncFloatingActions)
} else {
	document.addEventListener('swup:enable', () => {
		window.swup.hooks.on('page:view', syncFloatingActions)
	}, { once: true })
}

window.onresize = () => {
	// calculate the --banner-height-extend, which needs to be a multiple of 4 to avoid blurry text
	let offset = Math.floor(window.innerHeight * (BANNER_HEIGHT_EXTEND / 100));
	offset = offset - offset % 4;
	document.documentElement.style.setProperty('--banner-height-extend', `${offset}px`);
	scrollFunction()
}

</script>

<script>
	import PhotoSwipeLightbox from "photoswipe/lightbox"
	import "photoswipe/style.css"
	import {
		getZoomAnimationDuration,
		getNextReducedZoomLevel,
		getReducedZoomLevel,
		getReducedZoomMinLevel,
		getZoomedOutPanBounds,
	} from "../utils/photoswipe-controls.js"

	let lightbox: PhotoSwipeLightbox
	let pswp = import("photoswipe")
	const REDUCED_ZOOM_EPSILON = 0.01
	const ORIGINAL_IS_PANNABLE = Symbol("temperature-original-is-pannable")
	const zoomOutSVG = '<svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#ffffff"><path d="M340-540h120q17 0 28.5-11.5T500-580q0-17-11.5-28.5T460-620H340q-17 0-28.5 11.5T300-580q0 17 11.5 28.5T340-540Zm40 220q-109 0-184.5-75.5T120-580q0-109 75.5-184.5T380-840q109 0 184.5 75.5T640-580q0 44-14 83t-38 69l224 224q11 11 11 28t-11 28q-11 11-28 11t-28-11L532-372q-30 24-69 38t-83 14Zm0-80q75 0 127.5-52.5T560-580q0-75-52.5-127.5T380-760q-75 0-127.5 52.5T200-580q0 75 52.5 127.5T380-400Z"/></svg>'
	const resetZoomSVG = '<svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#ffffff"><path d="M480-80q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q69 0 132 22.5T726-792v-48q0-17 11.5-28.5T766-880q17 0 28.5 11.5T806-840v200q0 17-11.5 28.5T766-600H566q-17 0-28.5-11.5T526-640q0-17 11.5-28.5T566-680h126q-38-57-97-88.5T480-800q-134 0-227 93t-93 227q0 134 93 227t227 93q107 0 188.5-62.5T786-392q5-16 19-24t30-3q17 5 24.5 20t2.5 31Q826-257 735.5-168.5T480-80Z"/></svg>'

	function isReducedPreviewActive(slide: any) {
		return Boolean(slide) && slide.currZoomLevel < slide.zoomLevels.initial - REDUCED_ZOOM_EPSILON
	}

	// PhotoSwipe 默认只允许“大于适配尺寸”的图片拖拽。
	// 这里保留原始判定，同时给缩小态补一个兜底，让 50% 小图也能继续拖拽。
	function patchSlidePannable(slide: any) {
		if (!slide || slide[ORIGINAL_IS_PANNABLE]) {
			return
		}

		slide[ORIGINAL_IS_PANNABLE] = slide.isPannable.bind(slide)
		slide.isPannable = () => slide[ORIGINAL_IS_PANNABLE]() || isReducedPreviewActive(slide)
	}

	function getPhotoSwipePadding(options: Record<string, any>) {
		return {
			x: Number(options.padding?.left ?? options.paddingLeft ?? 0),
			y: Number(options.padding?.top ?? options.paddingTop ?? 0),
		}
	}

	function setButtonDisabled(button: HTMLButtonElement | null, disabled: boolean) {
		if (!button) {
			return
		}

		if (disabled) {
			button.disabled = true
		} else {
			button.disabled = false
		}
	}

	// 自定义按钮状态和手势开关都依赖当前缩放态。
	// 缩小到初始适配尺寸以下时，需要同时关闭“垂直拖拽关闭”和“拖到边缘切下一张”，
	// 否则用户拖小图时会频繁误触关闭或切图。
	function syncPreviewControls(current = lightbox?.pswp) {
		const pswpInstance = current
		const slide = pswpInstance?.currSlide
		const root = pswpInstance?.element

		if (!pswpInstance || !slide || !root) {
			return
		}

		patchSlidePannable(slide)

		const canZoom = slide.isZoomable()
		const reducedZoomLevel = getReducedZoomLevel(slide.zoomLevels.initial)
		const isReduced = isReducedPreviewActive(slide)
		const isAtInitialZoom = Math.abs(slide.currZoomLevel - slide.zoomLevels.initial) < REDUCED_ZOOM_EPSILON
		const isAtReducedZoom = Math.abs(slide.currZoomLevel - reducedZoomLevel) < REDUCED_ZOOM_EPSILON
			|| slide.currZoomLevel < reducedZoomLevel

		root.classList.toggle("pswp--reduced-preview", isReduced)
		pswpInstance.options.closeOnVerticalDrag = !isReduced
		pswpInstance.options.allowPanToNext = !isReduced

		setButtonDisabled(
			root.querySelector(".pswp__button--zoom-out") as HTMLButtonElement | null,
			!canZoom || isAtReducedZoom,
		)
		setButtonDisabled(
			root.querySelector(".pswp__button--reset-zoom") as HTMLButtonElement | null,
			!canZoom || isAtInitialZoom,
		)
	}

	function zoomSlide(slide: any, zoomLevel: number, ignoreBounds = false, duration?: number | false) {
		slide.zoomTo(zoomLevel, undefined, duration, ignoreBounds)
	}

	// 缩小按钮按默认放大按钮的反向倍率逐步缩小，并复用同一套缩放动画时长，
	// 这样按钮缩小、滚轮缩小和默认放大在体感上是一致的。
	function zoomCurrentSlideOut(current = lightbox?.pswp) {
		const slide = current?.currSlide

		if (!current || !slide || !slide.isZoomable()) {
			return
		}

		patchSlidePannable(slide)
		zoomSlide(
			slide,
			getNextReducedZoomLevel(slide.currZoomLevel, slide.zoomLevels),
			false,
			getZoomAnimationDuration(current.options),
		)
		syncPreviewControls(current)
	}

	function resetCurrentSlideZoom(current = lightbox?.pswp) {
		const slide = current?.currSlide

		if (!current || !slide || !slide.isZoomable()) {
			return
		}

		zoomSlide(
			slide,
			slide.zoomLevels.initial,
			false,
			getZoomAnimationDuration(current.options),
		)
		syncPreviewControls(current)
	}

	function createPhotoSwipe() {
		lightbox = new PhotoSwipeLightbox({
			gallery: ".custom-md img, #post-cover img",
			pswpModule: () => pswp,
			closeSVG: '<svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#ffffff"><path d="M480-424 284-228q-11 11-28 11t-28-11q-11-11-11-28t11-28l196-196-196-196q-11-11-11-28t11-28q11-11 28-11t28 11l196 196 196-196q11-11 28-11t28 11q11 11 11 28t-11 28L536-480l196 196q11 11 11 28t-11 28q-11 11-28 11t-28-11L480-424Z"/></svg>',
			zoomSVG: '<svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#ffffff"><path d="M340-540h-40q-17 0-28.5-11.5T260-580q0-17 11.5-28.5T300-620h40v-40q0-17 11.5-28.5T380-700q17 0 28.5 11.5T420-660v40h40q17 0 28.5 11.5T500-580q0 17-11.5 28.5T460-540h-40v40q0 17-11.5 28.5T380-460q-17 0-28.5-11.5T340-500v-40Zm40 220q-109 0-184.5-75.5T120-580q0-109 75.5-184.5T380-840q109 0 184.5 75.5T640-580q0 44-14 83t-38 69l224 224q11 11 11 28t-11 28q-11 11-28 11t-28-11L532-372q-30 24-69 38t-83 14Zm0-80q75 0 127.5-52.5T560-580q0-75-52.5-127.5T380-760q-75 0-127.5 52.5T200-580q0 75 52.5 127.5T380-400Z"/></svg>',
			padding: { top: 20, bottom: 20, left: 20, right: 20 },
			wheelToZoom: true,
			arrowPrev: false,
			arrowNext: false,
			imageClickAction: 'close',
			tapAction: 'close',
			doubleTapAction: 'zoom',
		})

		lightbox.on("uiRegister", () => {
			const pswpInstance = lightbox.pswp

			if (!pswpInstance || !pswpInstance.ui) {
				return
			}

			pswpInstance.ui.registerElement({
				name: "zoom-out",
				title: "Zoom out",
				ariaLabel: "Zoom out image",
				order: 9,
				isButton: true,
				html: zoomOutSVG,
				onClick: () => zoomCurrentSlideOut(pswpInstance),
			})

			pswpInstance.ui.registerElement({
				name: "reset-zoom",
				title: "Reset size",
				ariaLabel: "Reset image size",
				order: 11,
				isButton: true,
				html: resetZoomSVG,
				onClick: () => resetCurrentSlideZoom(pswpInstance),
			})
		})

		lightbox.addFilter("domItemData", (itemData, element) => {
			if (element instanceof HTMLImageElement) {
				itemData.src = element.src

				itemData.w = Number(element.naturalWidth || window.innerWidth)
				itemData.h = Number(element.naturalHeight || window.innerHeight)

				itemData.msrc = element.src
			}

			return itemData
		})

		// PhotoSwipe 在图片小于视口时会把边界收敛到中心点，导致缩小后无法拖拽。
		// 这里只在“缩小到初始适配尺寸以下”时覆盖边界，让小图仍然能在视口内移动。
		lightbox.on("calcBounds", ({ slide }) => {
			patchSlidePannable(slide)

			if (!isReducedPreviewActive(slide)) {
				return
			}

			const customBounds = getZoomedOutPanBounds({
				panAreaSize: slide.panAreaSize,
				elementSize: {
					x: slide.width * slide.currZoomLevel,
					y: slide.height * slide.currZoomLevel,
				},
				padding: getPhotoSwipePadding(slide.pswp.options),
			})

			Object.assign(slide.bounds.center, customBounds.center)
			Object.assign(slide.bounds.max, customBounds.max)
			Object.assign(slide.bounds.min, customBounds.min)
		})

		// 把滚轮缩放的最小下限放到“初始适配尺寸的 50%”，
		// 让滚轮、缩小按钮和禁用态判断共享同一终点。
		lightbox.on("zoomLevelsUpdate", ({ zoomLevels }) => {
			zoomLevels.min = getReducedZoomMinLevel(zoomLevels)
		})

		lightbox.on("afterInit", () => {
			syncPreviewControls(lightbox.pswp)
		})
		lightbox.on("change", () => {
			syncPreviewControls(lightbox.pswp)
		})
		lightbox.on("zoomPanUpdate", () => {
			syncPreviewControls(lightbox.pswp)
		})

		lightbox.init()
	}

const setup = () => {
	if (!lightbox) {
		createPhotoSwipe()
	}
	window.swup.hooks.on("page:view", () => {
		createPhotoSwipe()
	})

	window.swup.hooks.on(
		"content:replace",
		() => {
			lightbox?.destroy?.()
		},
		{ before: true },
	)
}

if (window.swup) {
	setup()
} else {
	document.addEventListener("swup:enable", setup)
}
</script>
